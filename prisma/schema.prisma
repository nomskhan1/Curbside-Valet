// Prisma schema for Curbside Valet
// Production datasource is Postgres (Neon).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Note: role/status/type are plain strings (not native enums) for portability.
// Valid values are enforced in application code
// (see lib/auth.js and the API routes in app/api/).
// role:   "GUEST" | "STAFF" | "MANAGER" | "ADMIN"
// status: "WAITING" | "PULLING" | "READY" | "COMPLETED" | "CANCELLED"
// type:   "PICKUP" | "CHARGE"

model Building {
  id        String   @id @default(cuid())
  name      String
  address   String?
  createdAt DateTime @default(now())

  users    User[]
  vehicles Vehicle[]
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  name         String
  role         String   @default("GUEST")
  createdAt    DateTime @default(now())

  // Which building this account belongs to. ADMIN accounts are typically
  // global and can leave this null; STAFF and GUEST should always have one.
  buildingId String?
  building   Building? @relation(fields: [buildingId], references: [id])

  vehicles        Vehicle[]
  requests        Request[] @relation("RequestedBy")
  handledRequests Request[] @relation("HandledBy")
}

model Vehicle {
  id           String  @id @default(cuid())
  make         String?
  model        String?
  color        String?
  licensePlate String?
  ticketNumber String   @unique
  ownerId      String
  owner        User     @relation(fields: [ownerId], references: [id])
  createdAt    DateTime @default(now())

  // True when this vehicle was registered on the fly by a resident
  // requesting pickup for a visitor's car, rather than their own.
  isVisitor Boolean @default(false)

  // "GASOLINE" | "ELECTRIC" | "PLUGIN_HYBRID" — determines whether the
  // charging request option is available for this vehicle.
  fuelType String @default("GASOLINE")

  // URL of an uploaded photo (stored in Vercel Blob), so staff can visually
  // identify the car. Optional.
  photoUrl String?

  // Random secret encoded in the guest-facing QR code. Lets someone with
  // no account/login hit a public page and request this specific vehicle.
  // Nullable so existing vehicles don't need a backfill to keep working.
  claimToken String? @unique

  // Denormalized from the owner's building at creation time, so queue
  // queries can filter by building without an extra join.
  buildingId String?
  building   Building? @relation(fields: [buildingId], references: [id])

  // Parking section/zone — mainly used for monthly parkers, where the
  // "ticket number" field doubles as their decal number. Optional and
  // freeform since section naming varies by garage.
  section String?

  requests Request[]
}

model Request {
  id            String    @id @default(cuid())
  vehicleId     String
  vehicle       Vehicle   @relation(fields: [vehicleId], references: [id])
  requestedById String
  requestedBy   User      @relation("RequestedBy", fields: [requestedById], references: [id])
  handledById   String?
  handledBy     User?     @relation("HandledBy", fields: [handledById], references: [id])
  status        String    @default("WAITING")
  // PICKUP = bring the car around. CHARGE = plug in / charge while parked,
  // independent of any pickup request for the same vehicle.
  type          String    @default("PICKUP")
  etaMinutes    Int       @default(0)
  // If set, this is a request for a future pickup time rather than "right now".
  // Staff still see it in the queue (so nothing gets missed), labeled with the time.
  scheduledFor  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  completedAt   DateTime?
}
