# Local dev: SQLite file database
DATABASE_URL="file:./dev.db"

# Production (Vercel): use a Postgres connection string instead, e.g.
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
# and change the `provider` in prisma/schema.prisma from "sqlite" to "postgresql"

# Secret used to sign login session tokens — set a long random string in production
JWT_SECRET="change-this-to-a-long-random-string"
